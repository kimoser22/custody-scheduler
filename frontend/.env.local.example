# Local dev: leave NEXT_PUBLIC_API_URL unset to use same-origin /api proxy (see next.config.ts rewrites).
# API_PROXY_TARGET=http://127.0.0.1:8000

# Production / Vercel (direct API on Fly):
# NEXT_PUBLIC_API_URL=https://custody-scheduler-api.fly.dev

# Optional: refresh openapi/schema.json from a live API (local only).
# When unset, `npm run generate:api` / `npm run build` uses the committed openapi/schema.json.
# API_OPENAPI_URL=http://localhost:8000/openapi.json
