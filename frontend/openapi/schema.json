            "title": "Id"
          },
          "override_date": {
            "type": "string",
            "format": "date",
            "title": "Override Date"
          },
          "assigned_parent": {
            "$ref": "#/components/schemas/ParentRole"
          },
          "override_type": {
            "$ref": "#/components/schemas/OverrideType"
          },
          "description": {
            "type": "string",
            "title": "Description"
          },
          "is_active": {
            "type": "boolean",
            "title": "Is Active",
            "default": true
          },
          "status": {
            "$ref": "#/components/schemas/OverrideStatus",
