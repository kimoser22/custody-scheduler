          "requested_by_user_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Requested By User Id"
          }
        },
        "type": "object",
        "required": [
          "override_date",
          "assigned_parent",
          "override_type",
          "description"
        ],
        "title": "ScheduleOverride"
      },
      "TokenRequest": {
        "properties": {
          "user_id": {
            "type": "integer",
            "title": "User Id"
          },
          "passcode": {
            "type": "string",
            "title": "Passcode"
          }
        },
        "type": "object",
        "required": [
          "user_id",
          "passcode"
        ],
        "title": "TokenRequest"
