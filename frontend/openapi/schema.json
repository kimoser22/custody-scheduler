{
  "openapi": "3.1.0",
  "info": {
    "title": "Custody Scheduler API",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/health": {
      "get": {
        "summary": "Health Check",
        "operationId": "health_check_api_v1_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Check Api V1 Health Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/rules": {
      "get": {
        "summary": "List Rules",
        "operationId": "list_rules_api_v1_rules_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/BaselineSchedule"
                  },
                  "type": "array",
                  "title": "Response List Rules Api V1 Rules Get"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Rule",
        "operationId": "create_rule_api_v1_rules_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BaselineSchedule"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BaselineSchedule"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/holidays": {
      "get": {
        "summary": "List Holidays",
        "operationId": "list_holidays_api_v1_holidays_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ScheduleOverride"
                  },
                  "type": "array",
                  "title": "Response List Holidays Api V1 Holidays Get"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Holiday",
        "operationId": "create_holiday_api_v1_holidays_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScheduleOverride"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScheduleOverride"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/schedule/": {
      "get": {
        "summary": "Get Schedule",
        "operationId": "get_schedule_api_v1_schedule__get",
        "parameters": [
          {
            "name": "start_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date",
              "title": "Start Date"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date",
              "title": "End Date"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DailyCustodyState"
                  },
                  "title": "Response Get Schedule Api V1 Schedule  Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/schedule/overrides": {
      "post": {
        "summary": "Create Override",
        "operationId": "create_override_api_v1_schedule_overrides_post",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Authorization"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScheduleOverride"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScheduleOverride"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BaselineSchedule": {
        "properties": {
          "epoch_start_date": {
            "type": "string",
            "format": "date",
            "title": "Epoch Start Date"
          },
          "starting_parent": {
            "$ref": "#/components/schemas/ParentRole"
          }
        },
        "type": "object",
        "required": [
          "epoch_start_date",
          "starting_parent"
        ],
        "title": "BaselineSchedule"
      },
      "DailyCustodyState": {
        "properties": {
          "current_date": {
            "type": "string",
            "format": "date",
            "title": "Current Date"
          },
          "baseline_parent": {
            "$ref": "#/components/schemas/ParentRole"
          },
          "final_parent": {
            "$ref": "#/components/schemas/ParentRole"
          },
          "is_overridden": {
            "type": "boolean",
            "title": "Is Overridden"
          },
          "override_details": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ScheduleOverride"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "current_date",
          "baseline_parent",
          "final_parent",
          "is_overridden"
        ],
        "title": "DailyCustodyState"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "OverrideType": {
        "type": "string",
        "enum": [
          "Holiday",
          "Mutual Swap",
          "Emergency"
        ],
        "title": "OverrideType"
      },
      "ParentRole": {
        "type": "string",
        "enum": [
          "Parent A",
          "Parent B"
        ],
        "title": "ParentRole"
      },
      "ScheduleOverride": {
        "properties": {
          "override_date": {
            "type": "string",
            "format": "date",
            "title": "Override Date"
          },
          "assigned_parent": {
            "$ref": "#/components/schemas/ParentRole"
          },
          "override_type": {
            "$ref": "#/components/schemas/OverrideType"
          },
          "description": {
            "type": "string",
            "title": "Description"
          },
          "is_active": {
            "type": "boolean",
            "title": "Is Active",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "override_date",
          "assigned_parent",
          "override_type",
          "description"
        ],
        "title": "ScheduleOverride"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}