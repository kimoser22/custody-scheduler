TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Local default is sqlite:///./custody.db when unset.
# Fly sets this via fly.toml to sqlite:////data/custody.db
# DATABASE_URL=sqlite:///./custody.db

# Comma-separated CORS origins (default: http://localhost:3000)
# ALLOWED_ORIGINS=http://localhost:3000,https://YOUR_APP.vercel.app

# Local demo only — never set on Fly. Allows wipe/recreate on SQLite schema drift.
# ALLOW_SQLITE_SCHEMA_RESET=1
