# REQUIRED. Secret used to sign/verify auth tokens (HMAC-SHA256). With this
# unset the API fails closed — every authenticated request returns 401. Use a
# long random value; set it as a Fly secret in production, never commit a real one.
AUTH_SIGNING_SECRET=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Local default is sqlite:///./custody.db when unset.
# Fly sets this via fly.toml to sqlite:////data/custody.db
# DATABASE_URL=sqlite:///./custody.db

# Comma-separated CORS origins (default: http://localhost:3000)
# ALLOWED_ORIGINS=http://localhost:3000,https://YOUR_APP.vercel.app

# Verbose SQLAlchemy statement logging (off by default). Local debugging only —
# it logs bound parameters (phone numbers, descriptions); never enable on Fly.
# SQL_ECHO=1

# Local demo only — never set on Fly. Allows wipe/recreate on SQLite schema drift.
# ALLOW_SQLITE_SCHEMA_RESET=1

# Local dev / simulator only — never set on Fly. The Twilio webhook fails closed
# when TWILIO_AUTH_TOKEN is unset; this flag opts out of signature verification
# so local testing without Twilio credentials still works.
# TWILIO_ALLOW_UNVERIFIED=1
